# =============================================
# 代码签名环境变量配置示例
# 复制此文件为 .env.sign 并填入真实值，打包前 source 加载
# Windows: 在 PowerShell 中逐行执行 $env:变量名="值"
# Mac/Linux: export 变量名=值 或 source .env.sign
# =============================================

# ── Windows 代码签名证书 ──────────────────────
# PFX/P12 证书文件路径（绝对路径或相对路径）
WIN_CSC_LINK=C:\certs\lisheng-code-sign.pfx

# PFX/P12 证书密码
WIN_CSC_KEY_PASSWORD=your_certificate_password

# ── Mac 签名与公证 ────────────────────────────
# Apple Developer 账号邮箱
APPLE_ID=your@email.com

# Apple ID 应用专用密码
# 生成地址：https://appleid.apple.com -> 安全 -> 应用专用密码
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Apple 开发者 Team ID
# 查看地址：https://developer.apple.com/account -> Membership
APPLE_TEAM_ID=XXXXXXXXXX
