{
  "name": "lisheng-live-pc",
  "chname": "Learn InClass",
  "version": "1.0.4",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "build:prod": "vue-cli-service build --mode production",
    "build:stage": "vue-cli-service build --mode staging",
    "lint": "vue-cli-service lint",
    "electron:serve": "cross-env NODE_ENV=development electron .",
    "electron:build": "vue-cli-service build --mode production && electron-builder build --win",
    "electron:build:mac": "vue-cli-service build --mode production && electron-builder build --mac",
    "electron:build:all": "vue-cli-service build --mode production && electron-builder build --win --mac",
    "electron:build:no-sign": "vue-cli-service build --mode production && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win"
  },
  "dependencies": {
    "aliyun-aliplayer": "^2.37.6",
    "axios": "^1.6.8",
    "core-js": "^3.49.0",
    "echarts": "^6.0.0",
    "element-ui": "^2.15.14",
    "js-cookie": "^3.0.5",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-texmath": "^1.0.0",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "vue": "^2.7.16",
    "vue-router": "^3.6.5",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-service": "~5.0.8",
    "cross-env": "^7.0.3",
    "electron": "^25.9.8",
    "electron-builder": "^26.8.1",
    "sass": "^1.69.7",
    "sass-loader": "^10.4.1"
  },
  "build": {
    "appId": "com.lisheng.live.pc",
    "productName": "Learn InClass",
    "copyright": "Copyright © 2024 立升",
    "icon": "build/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Learn InClass",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": true
    },
    "afterSign": "scripts/notarize.js",
    "mac": {
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "entitlements": "electron/entitlements.mac.plist",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Learn InClass需要录制屏幕以进行屏幕共享授课。",
        "NSCameraUsageDescription": "Learn InClass需要访问摄像头以进行视频直播。",
        "NSMicrophoneUsageDescription": "Learn InClass需要访问麦克风以进行语音直播。"
      }
    },
    "dmg": {
      "sign": false,
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
