{
  "name": "lisheng-live-pc",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "build:prod": "vue-cli-service build --mode production",
    "build:stage": "vue-cli-service build --mode staging",
    "lint": "vue-cli-service lint",
    "electron:serve": "cross-env NODE_ENV=development electron .",
    "electron:build": "vue-cli-service build --mode production && electron-builder build --win",
    "electron:build:mac": "vue-cli-service build --mode production && electron-builder build --mac",
    "electron:build:all": "vue-cli-service build --mode production && electron-builder build --win --mac"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "core-js": "^3.49.0",
    "element-ui": "^2.15.14",
    "js-cookie": "^3.0.5",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "vue": "^2.7.16",
    "vue-router": "^3.6.5",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-service": "~5.0.8",
    "cross-env": "^7.0.3",
    "electron": "^25.9.8",
    "electron-builder": "^23.6.0",
    "sass": "^1.69.7",
    "sass-loader": "^10.4.1"
  },
  "build": {
    "appId": "com.lisheng.live.pc",
    "productName": "立升直播",
    "copyright": "Copyright © 2024 立升",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "立升直播"
    },
    "mac": {
      "target": [
        {
          "target": "pkg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "public/favicon.ico"
    },
    "pkg": {
      "installLocation": "/Applications"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
